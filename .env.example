NODE_ENV=development
APP_NAME=backend-boilerplate
PORT=5000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
APP_ORIGINS=http://localhost:5000,http://192.168.1.13:5000
TRUST_PROXY=false
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=backend_boilerplate
DB_MAINTENANCE_NAME=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/backend_boilerplate
BOOTSTRAP_DB=true
BOOTSTRAP_ADMIN=true
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
LOG_LEVEL=debug
COOKIE_SECURE=false
