# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
NODE_ENV=development
APP_NAME=backend-boilerplate
PORT=5000
API_PREFIX=/api/v1

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Choose ONE of the following methods:
#
# METHOD 1: Connection String (RECOMMENDED for production & cloud deployments)
# Use this if you have a complete PostgreSQL connection string
# Supports: DATABASE_URL, POSTGRES_INTERNAL_URL, POSTGRES_URL, RENDER_DATABASE_URL
#
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/backend_boilerplate

# METHOD 2: Individual Components (RECOMMENDED for local development)
# Use this if you prefer to configure each component separately
# These are ONLY used if DATABASE_URL is not set
#
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=backend_boilerplate

# Additional Database Options
DB_MAINTENANCE_NAME=postgres
# BOOTSTRAP_DB=true
# BOOTSTRAP_ADMIN=true

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret-min-16-characters
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret-min-16-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
COOKIE_SECURE=false

# ============================================================================
# INITIAL ADMIN USER (created when BOOTSTRAP_ADMIN=true)
# ============================================================================
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# ============================================================================
# CORS & NETWORK
# ============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
APP_ORIGINS=http://localhost:5000,http://192.168.1.13:5000
# TRUST_PROXY=false

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
