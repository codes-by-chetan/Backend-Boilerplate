{
  "name": "backend_boilerplate",
  "version": "1.0.0",
  "description": "Node.js + Express + PostgreSQL backend boilerplate with auth, logging, config validation, and reusable middleware.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "format": "prettier --write .",
    "check:format": "prettier --check ."
  },
  "keywords": [
    "nodejs",
    "express",
    "postgresql",
    "boilerplate",
    "auth"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prettier": "^3.8.2",
    "prisma": "^7.7.0"
