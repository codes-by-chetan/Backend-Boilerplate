generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user
}

enum UserStatus {
  active
  inactive
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  name         String        @db.VarChar(120)
  email        String        @unique @db.VarChar(255)
  passwordHash String        @map("password_hash")
  role         Role          @default(user)
  status       UserStatus    @default(active)
  lastLoginAt  DateTime?     @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions     AuthSession[]
  requestLogs  RequestLog[]
  dbLogs       DbLog[]

  @@map("users")
}

model AuthSession {
  id               String   @id @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  refreshTokenHash String   @map("refresh_token_hash")
  userAgent        String?  @map("user_agent")
  ipAddress        String?  @map("ip_address") @db.VarChar(255)
  expiresAt        DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model RequestLog {
  id             String   @id @default(uuid()) @db.Uuid
  requestType    String   @map("request_type")
  requestStatus  String   @map("request_status")
  errors         String?
  ipAddress      Json     @map("ip_address")
  origin         String
  requestMethod  String   @map("request_method")
  requestUrl     String   @map("request_url")
  requestHeaders Json?    @map("request_headers")
  requestBody    Json?    @map("request_body")
  responseStatus Int?     @map("response_status")
  responseBody   Json?    @map("response_body")
  responseTimeMs Int?     @map("response_time_ms")
  userId         String?  @map("user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("request_logs")
}

model DbLog {
  id                  String   @id @default(uuid()) @db.Uuid
  previousValue       Json?    @map("previous_value")
  newValue            Json?    @map("new_value")
  status              String
  transactionType     String   @map("transaction_type")
  transactionDetails  String?  @map("transaction_details")
  affectedCollection  String   @map("affected_collection")
  affectedDocumentId  String   @map("affected_document_id")
  userId              String?  @map("user_id") @db.Uuid
  ipAddress           String?  @map("ip_address")
  origin              String?
  requestId           String?  @map("request_id")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([affectedCollection])
  @@index([createdAt])
  @@map("db_logs")
}
